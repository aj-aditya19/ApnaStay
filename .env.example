# Local environment for ApnaStay
# Set ATLASDB_URL to your MongoDB connection string. For local MongoDB use:
ATLASDB_URL=mongodb://127.0.0.1:27017/ApnaStay
# Session secret
SECRET=devsecret
# Cloudinary (set these if you use image uploads)
CLOUD_NAME=your_cloud_name
CLOUD_API_KEY=your_cloud_api_key
CLOUD_API_SECRET=your_cloud_api_secret
